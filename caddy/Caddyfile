# See wiki/caddy.md

:{$CADDY_CONTAINER_PORT} {
    # API endpoints require authentication
    handle /items* {
        @authorized {
            header Authorization *
        }
        @unauthorized {
            not header Authorization *
        }
        respond @unauthorized 401
        reverse_proxy @authorized http://app:{$APP_CONTAINER_PORT}
    }
    handle /learners* {
        @authorized {
            header Authorization *
        }
        @unauthorized {
            not header Authorization *
        }
        respond @unauthorized 401
        reverse_proxy @authorized http://app:{$APP_CONTAINER_PORT}
    }
    handle /interactions* {
        @authorized {
            header Authorization *
        }
        @unauthorized {
            not header Authorization *
        }
        respond @unauthorized 401
        reverse_proxy @authorized http://app:{$APP_CONTAINER_PORT}
    }
    handle /pipeline* {
        @authorized {
            header Authorization *
        }
        @unauthorized {
            not header Authorization *
        }
        respond @unauthorized 401
        reverse_proxy @authorized http://app:{$APP_CONTAINER_PORT}
    }
    handle /analytics* {
        @authorized {
            header Authorization *
        }
        @unauthorized {
            not header Authorization *
        }
        respond @unauthorized 401
        reverse_proxy @authorized http://app:{$APP_CONTAINER_PORT}
    }
    handle /docs* {
        reverse_proxy http://app:{$APP_CONTAINER_PORT}
    }
    handle /openapi.json {
        reverse_proxy http://app:{$APP_CONTAINER_PORT}
    }
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
